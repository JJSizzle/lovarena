NEXT_PUBLIC_SITE_URL=https://lovarena.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WebRTC TURN (optional — improves video behind strict firewalls)
# Use a provider like Twilio, Metered, or Cloudflare Calls
NEXT_PUBLIC_TURN_URL=turn:your-turn.example.com:3478
NEXT_PUBLIC_TURN_USERNAME=your-turn-username
NEXT_PUBLIC_TURN_CREDENTIAL=your-turn-credential

# Monitoring (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Email notifications (optional — wire up Resend/SendGrid later)
# RESEND_API_KEY=re_xxxx

# Supabase Auth (Dashboard → Authentication → URL Configuration)
# Site URL: https://lovarena.app  (NOT localhost)
# Redirect URLs (add all — wildcards cover ?next= query params):
#   https://lovarena.app/**
#   http://localhost:3000/**
#
# Email confirmation — Authentication → Email Templates → Confirm signup
# Replace the link body with (required for SSR / Next.js):
#   <a href="{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=email&next={{ .RedirectTo }}">Confirm email</a>
# Do NOT use {{ .ConfirmationURL }} alone — it often breaks on custom domains.
# After saving, use "Resend confirmation" — old emails keep the old link.
#
# Password reset uses /auth/callback (see forgot-password flow).

# Google Sign-In (fix "Access blocked" errors):
# 1. Google Cloud Console → APIs & Services → OAuth consent screen
#    - App name + support email required
#    - If Publishing status is "Testing", add each sign-in email under Test users
#    - Or publish the app for public use (may need verification at scale)
# 2. Google Cloud → Credentials → OAuth 2.0 Client ID (Web application)
#    - Authorized redirect URIs (exactly one Supabase callback):
#        https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#    - Do NOT put lovarena.app here — Google redirects to Supabase first
# 3. Supabase → Authentication → Providers → Google
#    - Paste Client ID + Client Secret from step 2, Enable
# 4. Supabase → Authentication → URL Configuration → Redirect URLs:
#        https://lovarena.app/**
#        http://localhost:3000/**

# SQL run order (Supabase SQL Editor):
# 1. orientation-matchmaking.sql
# 2. security-and-legal.sql
# 3. flagged-users.sql
# 4. platform-features.sql
# 5. spice-features.sql
# 6. profile-age-avatars.sql
# 7. username-policy.sql  ← 3–15 char usernames, periods allowed
