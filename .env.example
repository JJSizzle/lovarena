NEXT_PUBLIC_SITE_URL=https://lovarena.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WebRTC TURN (optional — helps video on strict Wi‑Fi / mobile networks)
# Easiest setup (recommended): Metered.ca free tier → one env var in Vercel
# 1. Sign up at https://www.metered.ca/stun-turn
# 2. Dashboard → create a TURN app (e.g. lovarena)
# 3. Open the credential → "Show API Key" → copy the full credentials URL, then paste:
# METERED_TURN_CREDENTIALS_URL=https://YOUR-APP.metered.live/api/v1/turn/credentials?apiKey=YOUR_KEY
#
# Alternative (two vars instead of one):
# METERED_TURN_APP=your-app-name
# METERED_TURN_API_KEY=your-api-key
#
# Legacy manual TURN (only if not using Metered):
# NEXT_PUBLIC_TURN_URL=turn:your-turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=your-turn-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-turn-credential

# Ops setup checklist:  npm run setup:ops

# Monitoring (optional — recommended before traffic spikes)
# 1. Create free project at https://sentry.io
# 2. Vercel → Environment Variables → NEXT_PUBLIC_SENTRY_DSN
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000.ingest.us.sentry.io/000

# Moderation alerts (optional — Slack and/or email when someone is reported)
# SLACK_MODERATION_WEBHOOK_URL=https://hooks.slack.com/services/...
# RESEND_API_KEY=re_xxxx
# ADMIN_ALERT_EMAIL=you@example.com
# RESEND_ALERTS_FROM_EMAIL=Lovarena <alerts@lovarena.app>
# RESEND_FROM_EMAIL=Lovarena <hello@lovarena.app>

# Contact form (/contact) — uses Resend + ADMIN_ALERT_EMAIL by default
# Optional per-topic inboxes (otherwise all go to ADMIN_ALERT_EMAIL):
# CONTACT_SUPPORT_EMAIL=support@lovarena.app
# CONTACT_SAFETY_EMAIL=safety@lovarena.app
# CONTACT_PRIVACY_EMAIL=privacy@lovarena.app
# CONTACT_LEGAL_EMAIL=legal@lovarena.app
# DNS: forward support@, safety@, privacy@, legal@ at your domain registrar

# Profile photo moderation (Sightengine — free tier at https://sightengine.com)
# SIGHTENGINE_API_USER=your-api-user
# SIGHTENGINE_API_SECRET=your-api-secret
# AVATAR_MODERATION_SKIP=1  ← local dev only; never set in production

# Daily auto-review cron (Vercel Hobby = once/day; Pro can use hourly 0 * * * *)
# CRON_SECRET=generate-a-long-random-string

# Email notifications (friend DMs — same RESEND_API_KEY as above)

# Web push — browser notifications for friend DMs and requests
# 1. Run locally:  npm run setup:web-push
# 2. Copy the one-line WEB_PUSH_VAPID_CREDENTIALS value into Vercel → Production → Redeploy
# 3. Check https://lovarena.app/api/health → webPushEnabled: true
# WEB_PUSH_VAPID_CREDENTIALS=yourPublicKey,yourPrivateKey
# WEB_PUSH_VAPID_SUBJECT=mailto:support@lovarena.app

# Supabase Auth (Dashboard → Authentication → URL Configuration)
# Site URL: https://lovarena.app  (NOT localhost)
# Redirect URLs (add all — wildcards cover ?next= query params):
#   https://lovarena.app/**
#   http://localhost:3000/**
#
# Email confirmation — Authentication → Email Templates → Confirm signup
# Replace the link body with (required for SSR / Next.js):
#   <a href="{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=email&next={{ .RedirectTo }}">Confirm email</a>
# Do NOT use {{ .ConfirmationURL }} alone — it often breaks on custom domains.
# After saving, use "Resend confirmation" — old emails keep the old link.
#
# Password reset uses /auth/callback (see forgot-password flow).

# Google Sign-In (fix "Access blocked" errors):
# 1. Google Cloud Console → APIs & Services → OAuth consent screen
#    - App name + support email required
#    - If Publishing status is "Testing", add each sign-in email under Test users
#    - Or publish the app for public use (may need verification at scale)
# 2. Google Cloud → Credentials → OAuth 2.0 Client ID (Web application)
#    - Authorized redirect URIs (exactly one Supabase callback):
#        https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#    - Do NOT put lovarena.app here — Google redirects to Supabase first
# 3. Supabase → Authentication → Providers → Google
#    - Paste Client ID + Client Secret from step 2, Enable
# 4. Supabase → Authentication → URL Configuration → Redirect URLs:
#        https://lovarena.app/**
#        http://localhost:3000/**

# SQL run order (Supabase SQL Editor):
# 1. orientation-matchmaking.sql
# 2. security-and-legal.sql
# 3. flagged-users.sql
# 4. platform-features.sql
# 5. spice-features.sql
# 6. profile-age-avatars.sql
# 7. username-policy.sql
# 8. username-change-limit.sql
# 9. secure-messages-rls.sql  ← or run production-security-bundle.sql (all-in-one)
# 10. production-security-bundle.sql  ← messages lockdown + rate limits (production)
# 11. realtime-chat-rooms.sql  ← instant stranger-left via Supabase Realtime
# 12. referral-rewards.sql  ← invite rewards + first-chat tracking
# 13. translation-prefs.sql  ← chat translation language settings
# 14. reputation-scale.sql  ← rep cap 500 + updated SQL functions
# 15. avatar-upload-moderation.sql  ← server-only avatar uploads (after moderation)
# 16. report-reasons.sql  ← expanded report categories
# 17. timed-restrictions.sql  ← 24h restrict + auto-review + matchmaking patch
# 18. security-tier2.sql  ← admin audit log + new-account match captcha grants

# Cloudflare Turnstile (login, contact, new-account match)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=...
# TURNSTILE_SECRET_KEY=...

# Admin hardening (optional — lock /admin API to known IPs)
# ADMIN_ALLOWED_IPS=203.0.113.10,198.51.100.5

# Translation (optional — DeepL for in-chat message translation)
# Free keys end with :fx and use api-free.deepl.com automatically
# DEEPL_AUTH_KEY=your-deepl-auth-key:fx
